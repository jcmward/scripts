#!/bin/sh
# Jon Ward, 2025.
# Delete directories generated by Visual Studio, to clear disk space.

rmvs() {
	dirs_to_delete=".vs Debug debug x64"
	start_dir="${1:-.}"

	for dir in $dirs_to_delete; do
		find "$start_dir" -type d -name "$dir" -prune -execdir rm -r -- {} \;
	done

	printf "Cleanup complete.\n"
}

rmvs "$@"

