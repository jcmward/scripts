#!/bin/sh
# Jon Ward, 2025.
# A CMake wrapper.  An alternative to this common workflow:
# cmake -S . -B build && cmake --build build

# Find project root by walking upward to CMakeLists.txt
find_project_root() {
	dir=$(pwd)
	while [ "$dir" != "/" ]; do
		if [ -f "$dir/CMakeLists.txt" ]; then
			printf "%s\n" "$dir"
			return 0
		fi
		dir="$(dirname "$dir")"
	done
	return 1
}

cm() {
	# Ensure CMake is installed
	if ! command -v cmake >/dev/null 2>&1; then
		printf "Error: CMake is not installed.\n" >&2
		return 1
	fi

	project_root="$(find_project_root)" || {
		printf "Error: No CMakeLists.txt found in this directory or any parent.\n" >&2
		return 1
	}

	build_dir="${CMAKE_BUILD_DIR:-$project_root/build}"

	printf "Project root: %s\n" "$project_root"
	printf "Build dir:    %s\n" "$build_dir"

	# Configure and build
	cmake -S "$project_root" -B "$build_dir" "$@" || return 1
	cmake --build "$build_dir" || return 1
}

cm "$@"

